{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ZoolandingNotificationPolicies",
  "type": "object",
  "required": ["version", "scope", "policies"],
  "properties": {
    "version": { "const": 1 },
    "scope": { "$ref": "#/definitions/scope" },
    "policies": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/definitions/policy" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "safeId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "domain": {
      "type": "string",
      "minLength": 4,
      "maxLength": 253,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)+$"
    },
    "scope": {
      "type": "object",
      "required": ["environment", "tenantId", "draftId", "domain"],
      "properties": {
        "environment": { "enum": ["test", "production"] },
        "tenantId": { "$ref": "#/definitions/safeId" },
        "draftId": { "$ref": "#/definitions/safeId" },
        "domain": { "$ref": "#/definitions/domain" }
      },
      "additionalProperties": false
    },
    "recipientMember": {
      "type": "object",
      "required": ["id"],
      "properties": { "id": { "$ref": "#/definitions/safeId" } },
      "additionalProperties": false
    },
    "recipientSet": {
      "type": "object",
      "required": ["id", "version", "members"],
      "properties": {
        "id": { "$ref": "#/definitions/safeId" },
        "version": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
        "members": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "$ref": "#/definitions/recipientMember" }
        }
      },
      "additionalProperties": false
    },
    "retryPolicy": {
      "type": "object",
      "required": ["maxAttempts"],
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1, "maximum": 5 }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": ["id", "status", "provider", "connectionId", "notificationTypes", "templateIds", "recipientSets", "retryPolicy", "acceptanceStatus"],
      "properties": {
        "id": { "$ref": "#/definitions/safeId" },
        "status": { "enum": ["disabled", "active"] },
        "provider": { "$ref": "#/definitions/safeId" },
        "connectionId": { "$ref": "#/definitions/safeId" },
        "notificationTypes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "enum": ["payment-succeeded", "payment-failed"] }
        },
        "templateIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "enum": ["payment-succeeded-v1", "payment-failed-v1"] }
        },
        "recipientSets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "$ref": "#/definitions/recipientSet" }
        },
        "retryPolicy": { "$ref": "#/definitions/retryPolicy" },
        "acceptanceStatus": { "const": "accepted_by_smtp" },
        "transportApprovalId": { "$ref": "#/definitions/safeId" }
      },
      "additionalProperties": false
    }
  }
}
